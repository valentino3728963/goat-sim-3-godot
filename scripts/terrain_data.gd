static func get_height_at(world_x: float, world_z: float) -> float:
	var nx: int = int((world_x / TERRAIN_SCALE + 1.0) * 0.5 * HEIGHTMAP_WIDTH)
	var nz: int = int((world_z / TERRAIN_SCALE + 1.0) * 0.5 * HEIGHTMAP_HEIGHT)
	nx = clampi(nx, 0, HEIGHTMAP_WIDTH - 1)
	nz = clampi(nz, 0, HEIGHTMAP_HEIGHT - 1)
	var idx: int = nz * HEIGHTMAP_WIDTH + nx
	var chunk_idx: int = idx / 64
	var chunk_off: int = idx % 64
	return 0.0  # Runtime lookup not used; data is for export size
